# ============================================
# MONGODB
# ============================================
MONGODB_CONNECTION_STRING=mongodb+srv://user:password@host/realtime-auction-platform
MONGODB_DATABASE_NAME=realtime-auction-platform

# ============================================
# JWT
# ============================================
JWT_SECRET_KEY=<generate-a-secure-random-key-at-least-64-characters>
JWT_ISSUER=realtime-auction-platform
JWT_AUDIENCE=realtime-auction-platform

# ============================================
# CAPTCHA / RECAPTCHA
# ============================================
CAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=<your-recaptcha-server-secret>
RECAPTCHA_MINIMUM_SCORE=0.5
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
RECAPTCHA_TIMEOUT_SECONDS=10

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ============================================
# PAYOS PAYMENT GATEWAY
# ============================================
PAYOS_CLIENT_ID=<your-payos-client-id>
PAYOS_API_KEY=<your-payos-api-key>
PAYOS_CHECKSUM_KEY=<your-payos-checksum-key>
PAYOS_RETURN_URL=http://localhost:5173/payment-success
PAYOS_CANCEL_URL=http://localhost:5173/orders

# ============================================
# CLOUDINARY (Image Upload)
# ============================================
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ============================================
# EMAIL (SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-email@gmail.com>
MAIL_PASSWORD=<your-app-password>
MAIL_FROM=Your App <your-email@gmail.com>
MAIL_REPLY_TO=<your-email@gmail.com>

# ============================================
# GEMINI AI (Optional)
# ============================================
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60

# ============================================
# FIREBASE CUSTOM TOKEN (Chat)
# ============================================
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_CLIENT_EMAIL=<your-firebase-service-account-client-email>
FIREBASE_PRIVATE_KEY=<your-firebase-service-account-private-key-with-\n-escapes>

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:5173
